# .secrets.env.example — copy to .secrets.env, fill in real values, NEVER commit .secrets.env
#
# Used by: scripts/seal.sh
# All values are sealed with kubeseal against pub-cert.pem before being written
# into platform/values.yaml — the plaintext never touches git.

# ── Keycloak Postgres (namespace: smartcity, secret: keycloak-db-auth) ──────
KC_DB_PASSWORD=change-me-keycloak-db

# ── Keycloak admin (namespace: smartcity, secret: keycloak-admin-creds) ─────
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=change-me-keycloak-admin

# ── Platform Application Secrets (namespace: smartcity) ─────────────────────
GRAFANA_OAUTH_SECRET=change-me-grafana-oauth
MQTT_EXPLORER_OAUTH_SECRET=change-me-mqtt-explorer-oauth2
NODE_RED_OAUTH_SECRET=change-me-node-red-oauth2
CB_PEP_SECRET=change-me-cb-pep-credentials
NGSILD_OAUTH_SECRET=change-me-ngsild-oauth
NODE_RED_NGSILD_SECRET=change-me-node-red-ngsild
CONSUMER_USER_PASSWORD=change-me-consumer-user-password
ADMIN_USER_PASSWORD=change-me-admin-user-password
EMQX_DASHBOARD_OAUTH_SECRET=change-me-emqx-dashboard-oauth2
NEXURBIS_MANAGER_OAUTH_SECRET=change-me-nexurbis-manager-oauth2
TSDB_PASSWORD=change-me-tsdb-password
NEXURBIS_DB_PASSWORD=change-me-nexurbis-db-password
EMQX_DASHBOARD_PASSWORD=change-me-emqx-dashboard
MONGODB_PASSWORD=change-me-mongodb-password
POSTGRES_PASSWORD=change-me-postgres-password
