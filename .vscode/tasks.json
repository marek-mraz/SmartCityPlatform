{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npx repomix",
      "type": "shell",
      "command": "fd --ignore-file .treeignore | tree --fromfile > tree.md && npx repomix",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "apply patch",
      "type": "shell",
      "command": "node apply_patch.js",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "deploy fiware",
      "type": "shell",
      "command": "./deploy-fiware.sh",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
