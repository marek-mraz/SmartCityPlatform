# .secrets.env.example — copy to .secrets.env, fill in real values, NEVER commit .secrets.env
#
# Used by: scripts/seal.sh
# All values are sealed with kubeseal against pub-cert.pem before being written
# into platform/values.yaml — the plaintext never touches git.

# ── WordPress (namespace: smartcity) ─────────────────────────────────────────
WP_MARIADB_ROOT_PASSWORD=change-me-root
WP_MARIADB_PASSWORD=change-me-wp-db
WP_WORDPRESS_PASSWORD=change-me-wp-admin
WP_OAUTH_CLIENT_SECRET=change-me-oauth-secret

# ── WordPress marek-mraz (namespace: smartcity) ─────────────────────────────
WP_MM_MARIADB_ROOT_PASSWORD=change-me-root
WP_MM_MARIADB_PASSWORD=change-me-wp-db
WP_MM_WORDPRESS_PASSWORD=change-me-wp-admin
WP_MM_OAUTH_CLIENT_SECRET=change-me-oauth-secret

# ── Keycloak Postgres (namespace: smartcity, secret: keycloak-db-auth) ──────
KC_DB_PASSWORD=change-me-keycloak-db

# ── Keycloak admin (namespace: smartcity, secret: keycloak-admin-creds) ─────
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=change-me-keycloak-admin

# ── Postgres Scorpio (namespace: smartcity, secret: postgres-auth) ──────────
POSTGRES_PASSWORD=change-me-postgres
